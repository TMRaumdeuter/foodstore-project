{
  "name": "foodstore",
  "version": "1.0.0",
  "private": true,
  "description": "Full-stack food ordering web application",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "npm run dev -w apps/api",
    "dev:web": "npm run dev -w apps/web",
    "dev:admin": "npm run dev -w apps/admin",
    "dev:all": "concurrently \"npm run dev:api\" \"npm run dev:web\" \"npm run dev:admin\"",
    "build:api": "npm run build -w apps/api",
    "build:web": "npm run build -w apps/web",
    "build:admin": "npm run build -w apps/admin",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
